{
  "schemaVersion": "2.0",
  "source": "Authoritative CargoWise eAdaptor Native Organization contract. Corrected/expanded against a real CW export (Reference/CargoWise_Organization_RealExport_Full.xml). Drives the Mapping page, auto-suggest, validation, and XML generation.",
  "ownerCodeDefault": "CENGLOBAL",
  "envelope": {
    "root": "Native",
    "xmlNamespace": "http://www.cargowise.com/Schemas/Native/2011/11",
    "version": "2.0",
    "note": "Root is <Native> directly (NOT wrapped in UniversalInterchange). Header carries OwnerCode + EnableCodeMapping. Every entity takes Action=\"MERGE\"; PK (GUID) is optional on import - omit to let CW match by Code."
  },
  "notes": [
    "type: string | bool | enum | code(reference lookup) | date | int | decimal",
    "Fields under collections repeat per row of source data grouped by a key (e.g. address code, contact name, GL company).",
    "aliases power the auto-mapping fuzzy match against incoming file headers.",
    "mapFromFile=false marks fields that are usually fixed defaults/system-managed (not mapped from client data) - shown in the Mapping page but not auto-suggested.",
    "refTable is the CargoWise TableName for code lookups - the inner <Code> must be a valid CW code (resolved via the transform/lookup layer).",
    "All mappings MUST pass the user-validation screen before XML is generated and sent."
  ],
  "enums": {
    "addressType": ["OFC (Office/Main)", "PMS (Premises)", "PAD (Postal)", "DAD (Delivery)", "ARM (AR/Billing)", "APM (AP/Remittance)", "WHS (Warehouse)", "BNK (Bank)", "CTC (Contact)"],
